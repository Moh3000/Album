<?php $this->headTitle('My Albums'); ?>

<h1>My Albums</h1>

<?php foreach ($this->flashMessenger()->getSuccessMessages() as $message) : ?>
    <div style="background:#d4edda; color:#155724; padding:10px; margin-bottom:10px; border-radius:4px;">
        <?= $this->escapeHtml($message) ?>
    </div>
<?php endforeach; ?>

<p>
    <a href="<?= $this->url('album', ['action' => 'add']) ?>">Add new album</a>
</p>

<table class="table table-striped table-bordered">
    <tr>
        <th>Title</th>
        <th>Artist</th>
        <th>Action</th>
    </tr>
    <?php foreach ($albums as $album) : ?>
        <tr>
            <td><?= $this->escapeHtml($album->getTitle()) ?></td>
            <td><?= $this->escapeHtml($album->getArtist()) ?></td>
            <td>
                <a href="<?= $this->url('album', ['action' => 'edit', 'id' => $album->getId()]) ?>">Edit</a>
                |
                <a href="<?= $this->url('album', ['action' => 'delete', 'id' => $album->getId()]) ?>">Delete</a>
            </td>
        </tr>
    <?php endforeach; ?>
</table>

<?php if ($totalPages > 1) : ?>
    <nav>
        <ul class="pagination">
            <?php if ($currentPage > 1) : ?>
                <li class="page-item">
                    <a class="page-link" href="<?= $this->url('album') ?>?page=<?= $currentPage - 1 ?>">«</a>
                </li>
            <?php endif; ?>

            <?php for ($i = 1; $i <= $totalPages; $i++) : ?>
                <li class="page-item <?= $i === $currentPage ? 'active' : '' ?>">
                    <a class="page-link" href="<?= $this->url('album') ?>?page=<?= $i ?>"><?= $i ?></a>
                </li>
            <?php endfor; ?>

            <?php if ($currentPage < $totalPages) : ?>
                <li class="page-item">
                    <a class="page-link" href="<?= $this->url('album') ?>?page=<?= $currentPage + 1 ?>">»</a>
                </li>
            <?php endif; ?>
        </ul>
    </nav>
<?php endif; ?>